root = true

[*.cs]

# Use latest C# formatting rules
csharp_new_line_before_open_brace = none

# Optional but common preferences
indent_style = tab
indent_size = 4
end_of_line = lf
insert_final_newline = true

# Keep simple blocks on one line if possible
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = true